@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Samet Yücel | @Localizer["JobTitle"] | .NET Core</title>
    <meta name="description" content="@Localizer["SeoDescription"]" />
    <meta name="keywords" content="@Localizer["SeoKeywords"]" />
    <meta name="author" content="Samet Yücel" />
    <link rel="canonical" href="https://syweach.com" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://syweach.com" />
    <meta property="og:title" content="Samet Yücel | @Localizer["JobTitle"] | .NET Core" />
    <meta property="og:description" content="@Localizer["SeoDescription"]" />
    <meta property="og:image" content="https://syweach.com/images/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://syweach.com" />
    <meta property="twitter:title" content="Samet Yücel | @Localizer["JobTitle"] | .NET Core" />
    <meta property="twitter:description" content="@Localizer["SeoDescription"]" />
    <meta property="twitter:image" content="https://syweach.com/images/og-image.jpg" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "Person",
      "name": "Samet Yücel",
      "url": "https://syweach.com",
      "jobTitle": "Backend Developer",
      "knowsAbout": ["ASP.NET Core", ".NET Core", "C#", "MS SQL Server", "Backend Development"],
      "sameAs": [
        "https://www.linkedin.com/in/samet-yücel-0065b1159/",
        "https://github.com/sametycll",
        "https://x.com/SametWeach"
      ]
    }
    </script>
    
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><defs><linearGradient id=%22g%22 x1=%220%%22 y1=%220%%22 x2=%22100%%22 y2=%22100%%22><stop offset=%220%%22 style=%22stop-color:%23e60000;stop-opacity:1%22 /><stop offset=%22100%%22 style=%22stop-color:%23990000;stop-opacity:1%22 /></linearGradient></defs><path d=%22M50 5L90 25V75L50 95L10 75V25L50 5Z%22 fill=%22%230f172a%22 stroke=%22url(%23g)%22 stroke-width=%228%22/><text x=%2250%22 y=%2265%22 font-family=%22Arial%22 font-weight=%22bold%22 font-size=%2245%22 fill=%22%23ffffff%22 text-anchor=%22middle%22>S</text></svg>">
    
    <!-- Tailwind Output -->
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    
    <!-- Devicon for tech icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass { background: rgba(18, 18, 18, 0.7); backdrop-filter: blur(10px); }
    </style>
</head>
<body class="bg-brand-black text-gray-100 selection:bg-brand-red selection:text-white">
    
    <!-- Header/Nav -->
    <header class="fixed top-0 left-0 right-0 z-50 glass border-b border-gray-800">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center">
                    <a asp-controller="Home" asp-action="Index" class="text-2xl font-bold tracking-tighter text-white">
                        SYWEACH<span class="text-brand-red">.</span>
                    </a>
                </div>
                
                <div class="hidden md:block">
                    <div class="ml-10 flex items-baseline space-x-8">
                        <a href="#about" class="nav-link">@Localizer["About"]</a>
                        <a href="#projects" class="nav-link">@Localizer["Projects"]</a>
                        <a href="#skills" class="nav-link">@Localizer["Skills"]</a>
                        <a href="#contact" class="nav-link">@Localizer["Contact"]</a>
                        
                        <!-- Language Switcher -->
                        <div class="flex items-center space-x-3 ml-4 border-l border-gray-700 pl-4">
                            <form asp-controller="Home" asp-action="SetLanguage" method="post" class="inline">
                                <input type="hidden" name="culture" value="en" />
                                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                <button type="submit" class="text-sm hover:text-brand-red transition-all cursor-pointer @(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "en" ? "text-brand-red font-bold" : "text-gray-400 opacity-60 hover:opacity-100")">EN</button>
                            </form>
                            <span class="text-gray-600">|</span>
                            <form asp-controller="Home" asp-action="SetLanguage" method="post" class="inline">
                                <input type="hidden" name="culture" value="tr" />
                                <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                                <button type="submit" class="text-sm hover:text-brand-red transition-all cursor-pointer @(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "tr" ? "text-brand-red font-bold" : "text-gray-400 opacity-60 hover:opacity-100")">TR</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Mobile Menu Button -->
                <div class="md:hidden">
                    <button type="button" class="text-gray-400 hover:text-white focus:outline-none">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                        </svg>
                    </button>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-brand-navy-dark border-t border-gray-800 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="flex justify-center space-x-6 mb-8">
                <a href="https://www.linkedin.com/in/samet-yücel-0065b1159/" class="text-gray-400 hover:text-brand-red transition-colors">
                    <i class="devicon-linkedin-plain text-2xl"></i>
                </a>
                <a href="https://github.com/sametycll" class="text-gray-400 hover:text-brand-red transition-colors">
                    <i class="devicon-github-original text-2xl"></i>
                </a>
                <a href="https://x.com/SametWeach" class="text-gray-400 hover:text-brand-red transition-colors">
                    <i class="devicon-twitter-original text-2xl"></i>
                </a>
            </div>
            <p class="text-gray-500 text-sm">
                &copy; 2026 syweach.com - @Localizer["Version"]: v.1.0.0
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
